# Copy to .env.local and fill in.

# Connection code for authorizing web chat connectors.
# Leave blank and setup:web generates one.
LEARN_MCP_TOKEN=

# Local port the HTTP server listens on. Tailscale Funnel proxies your stable
# public URL (https://<device>.<tailnet>.ts.net) to this port — no domain to
# reserve, and the URL stays the same across reboots.
PORT=8787

# Optional: npm run login can autofill WatIAM credentials before waiting for
# manual Duo approval. A bare username is submitted as username@uwaterloo.ca.
# You can also set the full username@uwaterloo.ca value yourself.
WATIAM_USERNAME=
WATIAM_PASSWORD=
